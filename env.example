# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# cp env.example .env

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------------------
# LLM settings
# ---------------------------------------------------------------------------

# Model to use. Check https://console.groq.com/docs/models for the current list.
# Good choices for tool-use (July 2025):
#   moonshotai/kimi-k2-instruct   — strong tool-use + long context (default)
#   llama-3.3-70b-versatile       — reliable, broadly available
#   llama3-70b-8192               — fast 70B option
GROQ_MODEL=moonshotai/kimi-k2-instruct

# Low temperature = deterministic, focused reasoning (recommended for ops)
GROQ_TEMPERATURE=0.2

# Max tokens per LLM response
GROQ_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Execution mode
# ---------------------------------------------------------------------------

# supervised  (default) — pauses at CLI for confirmation before destructive actions
# autonomous            — runs end-to-end; destructive actions are HARD-BLOCKED
# dry_run               — simulates every command, executes nothing real
EXECUTION_MODE=supervised

# ---------------------------------------------------------------------------
# Agent loop safety limits
# ---------------------------------------------------------------------------

# Hard cap on the number of tool-call turns before the agent halts safely
MAX_AGENT_STEPS=40

# Max auto-retries for transient failures (network, timeout, rate-limit)
MAX_TOOL_RETRIES=3

# Exponential backoff base delay in seconds
RETRY_BASE_DELAY_SEC=2.0

# Total time ceiling for retries on a single step (seconds)
RETRY_MAX_TOTAL_SEC=300.0

# Default shell command timeout in seconds
DEFAULT_COMMAND_TIMEOUT_SEC=120

# ---------------------------------------------------------------------------
# Deploy / canary configuration
# ---------------------------------------------------------------------------

# Canary traffic steps (comma-separated percentages)
CANARY_STEPS=5,25,50,100

# Seconds to hold and observe metrics at each canary step
CANARY_BAKE_SEC=60

# Auto-rollback if error rate exceeds this fraction (0.02 = 2%)
CANARY_ERROR_THRESHOLD=0.02

# Auto-rollback if p95 latency exceeds this value in ms
CANARY_LATENCY_THRESHOLD_MS=500

# Post-deploy monitoring window in seconds (before declaring success)
BAKE_WINDOW_SEC=300

# Multi-region rollout
MULTI_REGION=false
REGIONS=us-east-1
REGION_BAKE_SEC=120

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Scan build artifacts for accidentally committed secrets before deploy
SECRET_SCAN_ENABLED=true

# ---------------------------------------------------------------------------
# Change correlation metadata (for incident tracing)
# ---------------------------------------------------------------------------

DEPLOY_AUTHOR=
TICKET_ID=

# ---------------------------------------------------------------------------
# Notifications (off by default — no-op until you set a URL)
# ---------------------------------------------------------------------------

NOTIFICATIONS_ENABLED=false

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# Generic JSON webhook (called for all events)
NOTIFY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Directory for structured JSONL audit logs (one file per run)
LOG_DIR=./deployment_logs
